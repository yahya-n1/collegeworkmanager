<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="14.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="group_three.collegeworkmanager.controller.LoginController"
      prefWidth="400.0" prefHeight="500.0"
      style="-fx-background-color: #f0f4f8;">
    <padding>
        <Insets top="60.0" bottom="60.0" left="60.0" right="60.0"/>
    </padding>

    <Label text="College Work Manager"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="Sign in to your account"
           style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>

    <TextField fx:id="emailField" promptText="Email address"
               prefWidth="280.0"
               style="-fx-font-size: 14px; -fx-padding: 8;"/>
    <PasswordField fx:id="passwordField" promptText="Password"
                   prefWidth="280.0"
                   style="-fx-font-size: 14px; -fx-padding: 8;"/>

    <Button fx:id="loginButton" text="Login" onAction="#handleLogin"
            prefWidth="280.0"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10; -fx-cursor: hand; -fx-background-radius: 4;"/>

    <Hyperlink text="Don't have an account? Sign up" onAction="#goToSignup"
               style="-fx-font-size: 13px;"/>

    <Label fx:id="errorLabel" wrapText="true" maxWidth="280.0"
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>
</VBox>
