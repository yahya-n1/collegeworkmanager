<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="group_three.collegeworkmanager.controller.FacultyDashboardController"
      prefWidth="950.0" prefHeight="650.0">

    <!-- Top Bar -->
    <HBox alignment="CENTER_LEFT" spacing="10.0"
          style="-fx-background-color: #8e44ad; -fx-padding: 10 15 10 15;">
        <Label text="College Work Manager — Faculty"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="facultyNameLabel" style="-fx-text-fill: #e8daef; -fx-font-size: 13px;"/>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS">

        <!-- ── My Courses ── -->
        <Tab text="My Courses" closable="false">
            <SplitPane dividerPositions="0.28">

                <!-- Left: course list -->
                <VBox spacing="6.0" minWidth="180.0">
                    <padding><Insets top="10" right="8" bottom="10" left="10"/></padding>
                    <Label text="My Courses" style="-fx-font-weight: bold;"/>
                    <ListView fx:id="courseListView" VBox.vgrow="ALWAYS"/>
                </VBox>

                <!-- Right: assignments for selected course -->
                <VBox spacing="8.0">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <Label fx:id="selectedCourseLabel" text="← Select a course"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
                    <HBox spacing="8.0">
                        <Button text="+ Create Assignment" onAction="#handleCreateAssignment"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                        <Button fx:id="editAssignBtn" text="Edit" onAction="#handleEditAssignment"
                                style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
                        <Button fx:id="deleteAssignBtn" text="Delete" onAction="#handleDeleteAssignment"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                    </HBox>
                    <TableView fx:id="assignmentTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="assignTitleCol"   text="Title"       prefWidth="180"/>
                            <TableColumn fx:id="assignDueDateCol" text="Due Date"    prefWidth="110"/>
                            <TableColumn fx:id="assignDescCol"    text="Description" prefWidth="260"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

            </SplitPane>
        </Tab>

        <!-- ── Submissions ── -->
        <Tab text="Submissions" closable="false">
            <VBox spacing="10.0">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Course:"/>
                    <ComboBox fx:id="submissionCourseCombo" prefWidth="220"/>
                    <Label text="Assignment:"/>
                    <ComboBox fx:id="submissionAssignCombo" prefWidth="220"/>
                    <Button text="Load Submissions" onAction="#handleLoadSubmissions"
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white;"/>
                </HBox>
                <TableView fx:id="submissionsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="subStudentCol" text="Student"      prefWidth="160"/>
                        <TableColumn fx:id="subDateCol"    text="Submitted At" prefWidth="160"/>
                        <TableColumn fx:id="subContentCol" text="Content"      prefWidth="250"/>
                        <TableColumn fx:id="subFileCol"    text="File URL"     prefWidth="200"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
