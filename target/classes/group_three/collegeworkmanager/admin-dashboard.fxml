<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="group_three.collegeworkmanager.controller.AdminDashboardController"
      prefWidth="950.0" prefHeight="650.0">

    <!-- Top Bar -->
    <HBox alignment="CENTER_LEFT" spacing="10.0"
          style="-fx-background-color: #2c3e50; -fx-padding: 10 15 10 15;">
        <Label text="College Work Manager — Admin"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="adminNameLabel" style="-fx-text-fill: #bdc3c7; -fx-font-size: 13px;"/>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS">

        <!-- ── User Management ── -->
        <Tab text="User Management" closable="false">
            <VBox spacing="8.0">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <HBox spacing="8.0">
                    <Button text="Assign Role"  onAction="#handleAssignRole"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                    <Button text="Edit Name"    onAction="#handleEditName"
                            style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
                    <Button text="Delete User"  onAction="#handleDeleteUser"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                    <Button text="Refresh"      onAction="#loadUsers"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
                </HBox>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="userNameCol"  text="Name"  prefWidth="220"/>
                        <TableColumn fx:id="userEmailCol" text="Email" prefWidth="260"/>
                        <TableColumn fx:id="userRoleCol"  text="Role"  prefWidth="120"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </Tab>

        <!-- ── Courses ── -->
        <Tab text="Courses" closable="false">
            <VBox spacing="8.0">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <HBox spacing="8.0">
                    <Button text="Create Course"    onAction="#handleCreateCourse"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                    <Button text="Manage Students"  onAction="#handleManageStudents"
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white;"/>
                    <Button text="Refresh"          onAction="#loadCourses"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
                </HBox>
                <TableView fx:id="courseTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="courseNameCol"    text="Course Name" prefWidth="280"/>
                        <TableColumn fx:id="courseCodeCol"    text="Code"        prefWidth="100"/>
                        <TableColumn fx:id="courseFacultyCol" text="Faculty ID"  prefWidth="220"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
